<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_approval_request" model="mail.template">
            <field name="name">Approval Request — Pending Your Review</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="subject">Action Required: Approval Request {{ object.name }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <h2 style="color: #875A7B;">Approval Request Pending Your Review</h2>
    <p>Dear {{ object.name }},</p>
    <p>An approval request requires your attention:</p>
    <table style="width:100%; border-collapse: collapse; margin: 16px 0;">
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Reference</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ ctx.get('request_name', '') }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Document</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ ctx.get('res_name', '') }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Deadline</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ ctx.get('deadline', 'N/A') }}</td>
        </tr>
    </table>
    <p>
        <a href="{{ ctx.get('approval_url', '#') }}"
           style="background:#875A7B; color:white; padding:10px 20px; text-decoration:none; border-radius:4px;">
            Review Request
        </a>
    </p>
    <p style="color:#888; font-size:12px;">This is an automated notification from Odoo Approval Workflow.</p>
</div>
            ]]></field>
            <field name="email_from">{{ (object.company_id.email or '') | safe }}</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="auto_delete" eval="True"/>
        </record>

        <record id="mail_template_approval_granted" model="mail.template">
            <field name="name">Approval Request — Fully Approved</field>
            <field name="model_id" ref="model_approval_request"/>
            <field name="subject">✓ Approved: {{ object.name }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <h2 style="color: #28a745;">Request Approved</h2>
    <p>Dear {{ object.requester_id.name }},</p>
    <p>Your approval request <strong>{{ object.name }}</strong> has been fully approved
       through all {{ object.total_levels }} level(s).</p>
    <p style="color:#888; font-size:12px;">Odoo Approval Workflow</p>
</div>
            ]]></field>
            <field name="email_from">{{ (object.company_id.email or '') | safe }}</field>
            <field name="email_to">{{ object.requester_id.email }}</field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
